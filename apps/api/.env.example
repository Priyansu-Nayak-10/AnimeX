SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key
# Optional: provide one of these for faster local JWT verification (otherwise we fallback to Supabase admin)
SUPABASE_JWT_PUBLIC_KEY=
JWT_SECRET=
SUPABASE_JWT_SECRET=
PORT=5000
BACKEND_URL=http://localhost:5000
# Comma-separated list of allowed web origins for CORS and Socket.IO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000
# Back-compat single origin (used if ALLOWED_ORIGINS is empty)
CLIENT_ORIGIN=http://localhost:3000
JIKAN_API_URL=https://api.jikan.moe/v4
VAPID_SUBJECT=mailto:admin@example.com
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
REDIS_URL=redis://localhost:6379
# Cache namespace to avoid key collisions across envs/deploys
CACHE_NAMESPACE=animex:v1
# If running behind reverse proxy (e.g., Nginx/Heroku), set to 1
TRUST_PROXY=0
# Opt-in to strict Content-Security-Policy (enable after adjusting frontend)
ENABLE_CSP=0
