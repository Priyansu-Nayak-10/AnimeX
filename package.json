{
  "name": "animex-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.5.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build:web": "npm run build --workspace=apps/web",
    "install:all": "npm install",
    "lint": "node apps/api/node_modules/.bin/eslint \"apps/api/src/**/*.js\"",
    "lint:fix": "node apps/api/node_modules/.bin/eslint \"apps/api/src/**/*.js\" --fix"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0"
  },
  "devDependencies": {
    "turbo": "^2.8.16"
  }
}
